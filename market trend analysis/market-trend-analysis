_height()\n","        plt.errorbar(\n","            x=x,\n","            y=y,\n","            yerr=row[\"std_win_rate_pct\"],\n","            fmt=\"none\",\n","            ecolor=\"black\",\n","            elinewidth=1.2,\n","            capsize=4\n","        )\n","\n","# --- Add value labels above each bar ---\n","for bar, (_, row) in zip(ax.patches, df.iterrows()):\n","    y = bar.get_height()\n","    x = bar.get_x() + bar.get_width() / 2\n","    plt.text(\n","        x,\n","        y + 1.0,\n","        f\"{row['win_rate_pct']:.1f}%±{row['std_win_rate_pct']:.1f}\",\n","        ha=\"center\",\n","        va=\"bottom\",\n","        fontsize=9\n","    )\n","\n","# --- Labels and title ---\n","plt.title(\n","    \"Automation Model Performance on Market Trend Task\\n\"\n","    \"(Mean Pairwise Win Rate ± 1 SD)\",\n","    fontsize=17,\n","    weight=\"bold\"\n",")\n","plt.ylabel(\"Average Pairwise Win Rate (%)\", fontsize=13)\n","plt.xlabel(\"Automation Model\", fontsize=12)\n","plt.xticks(rotation=30, ha=\"right\", fontsize=11)\n","plt.ylim(0, 100)\n","plt.tight_layout()\n","\n","# --- Save & show ---\n","plt.savefig(\"market_trend_automation_winrate.png\", dpi=300, bbox_inches=\"tight\")\n","plt.show()"],"metadata":{"id":"cV1i0jXO7-11","colab":{"base_uri":"https://localhost:8080/","height":619},"executionInfo":{"status":"ok","timestamp":1773622883153,"user_tz":420,"elapsed":1534,"user":{"displayName":"Kenny Wongchamcharoen","userId":"06797165778644515993"}},"outputId":"3c103f62-8911-4b53-fbde-a046250491c7"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import shutil\n","from google.colab import files\n","import os\n","\n","output_folder = \"market-trend-outputs\"\n","results_folder = \"market-trend-results\"\n","zip_name = \"market-trend-result\"\n","\n","# Create the zip archive\n","if os.path.exists(output_folder):\n","    s