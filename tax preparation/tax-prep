win rate to percent ---\n","df[\"run_avg_win_rate_pct\"] = df[\"run_avg_win_rate\"] * 100\n","\n","# --- Sort for display ---\n","df = df.sort_values(by=[\"assistant_model\", \"condition\"])\n","\n","# --- Seaborn style ---\n","sns.set(style=\"whitegrid\", context=\"talk\", font_scale=1.1)\n","plt.figure(figsize=(14, 7))\n","\n","# --- Barplot with automatic SD across runs ---\n","ax = sns.barplot(\n","    data=df,\n","    x=\"assistant_model\",\n","    y=\"run_avg_win_rate_pct\",\n","    hue=\"condition\",\n","    errorbar=\"sd\",\n","    palette={\"Plain\": \"#4C72B0\", \"Scaffolded\": \"#55A868\"},\n",")\n","\n","# --- Add value labels from summary stats ---\n","summary_df = (\n","    df.groupby([\"assistant_model\", \"condition\"], observed=True)[\"run_avg_win_rate_pct\"]\n","    .agg([\"mean\", \"std\"])\n","    .reset_index()\n",")\n","\n","condition_order = [\"Plain\", \"Scaffolded\"]\n","summary_df[\"condition\"] = pd.Categorical(\n","    summary_df[\"condition\"],\n","    categories=condition_order,\n","    ordered=True\n",")\n","summary_df = summary_df.sort_values([\"assistant_model\", \"condition\"])\n","\n","for bar, (_, row) in zip(ax.patches, summary_df.iterrows()):\n","    x = bar.get_x() + bar.get_width() / 2\n","    y = bar.get_height()\n","    sd = 0.0 if pd.isna(row[\"std\"]) else row[\"std\"]\n","\n","    plt.text(\n","        x,\n","        y + 1.0,\n","        f\"{row['mean']:.1f}%±{sd:.1f}\",\n","        ha=\"center\",\n","        va=\"bottom\",\n","        fontsize=9\n","    )\n","\n","# --- Labels, title, legend ---\n","plt.title(\n","    \"Augmentation Win Rate (Tax Preparer)\\n\"\n","    \"(Mean Pairwise Win Rate ± 1 SD Across Runs)\",\n","    fontsize=17,\n","    weight=\"bold\"\n",")\n","plt.ylabel(\"Average Pairwise Win Rate (%)\", fontsize=13)\n","plt.xlabel(\"Assistant Scaffold Model\", fontsize=12)\n","plt.xticks(rotation=30, ha=\"right\", fontsize=11)\n","plt.ylim(0, 100)\n","plt.axhline(50, linestyle=\"--\", color=\"gray\", alpha=0.6)\n","plt.legend(title=\"Condition\", title_fontsize=12, fontsize=11)\n","plt.tight_layout()\n","\n","# --- Save & show ---\n","plt.savefig(\"tax_preparer_scaffold_winrate.png\", dpi=300, bbox_inches=\"tight\")\n","plt.show()"],"metadata":{"id":"NzQ0dB975_3r","colab":{"base_uri":"https://localhost:8080/","height":677},"executionInfo":{"status":"ok","timestamp":1773714712768,"user_tz":420,"elapsed":1217,"user":{"displayName":"Kenny Wongchamcharoen","userId":"06797165778644515993"}},"outputId":"1ea43101-6724-4e03-e5d0-179ddc7d719f"},"execution_count":34,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# Automation"],"metadata":{"id":"1QYgtYu76Oxp"}},{"cell_type":"code","source":["# =========================================================\n","# Direct Model Comparison (Each Model Does the Task Itself)\n","# =========================================================\n","from edsl import Agent, Model, Scenario, ScenarioList, Survey, QuestionFreeText\n","import pandas as pd\n","from pathlib import Path\n","\n","# ---------------------------------------------------------\n","# 1. Experiment Configuration\n","# ---------------------------------------------------------\n","N_REPLICATES = 1\n","\n","TASK_MODELS = {\n","    \"gpt-3.5-turbo\": \"GPT-3.5-Turbo\",\n","    \"gpt-4.1\": \"GPT-4.1\",\n","    \"deepseek-ai/DeepSeek-V3.1\": \"DeepSeek-V3.1\",\n","    \"o4-mini-2025-04-16\": \"GPT-O4-Mini\",\n","    \"o3-mini-2025-01-31\": \"GPT-O3-Mini\",\n","    \"openai/gpt-oss-120b\": \"GPT-OSS-120B\",\n","    \"anthropic.claude-3-5-sonnet-20240620-v1:0\": \"Claude-3.5-Sonnet\",\n","    \"gpt-5.4\": \"gpt-5.4\",\n","    \"claude-opus-4-6\": \"Claude-Opus-4.6\",\n","    \"gemini-3.1-pro-preview\": \"Gemini-3.1-Pro\",\n","}\n","\n","# ---------------------------------------------------------\n","# 2. Task\n","# ---------------------------------------------------------\n","TASK_NAME = \"tax_preparer\"\n","TASK_PROMPT = \"\"\"\n","A client brings you their partially completed federal and state tax returns.\n","\n","They provide the following information and documents:\n","\n","W-2 income: $68,500\n","\n","Freelance/contract income: $4,200 reported on 1099-NEC\n","\n","Mortgage interest paid: $9,800\n","\n","One dependent listed: a 22-year-old full-time college student who earned $18,000 last year\n","\n","Filing status they selected: Single\n","\n","Pre-filled portions of their Form 1040 and state return:\n","\n","Form 1040 already has their freelance income entered as $2,400\n","\n","A standard deduction amount is already typed into Line 12\n","\n","Their state tax form shows a computed tax liability that does not match the AGI shown\n","\n","All calculations were done by the client before coming to you\n","\n","Your task: In one comprehensive response, behave exactly like a professional tax preparer and do ALL of the following:\n","\n","1. Explain Applicable Federal & State Tax Rules\n","\n","Explain the federal and state tax laws relevant to:\n","- reporting self-employment income\n","- deductibility of mortgage interest\n","- who qualifies as a dependent under IRS rules\n","- the correct standard deduction for their filing status\n","\n","2. Review Their Forms and Check for Accuracy\n","\n","Examine all numbers they have provided\n","- Verify arithmetic and data entry\n","- Spot and explain any errors, inconsistencies, or misreported amounts\n","- Recalculate income, AGI, deductions, taxable income, and estimated federal & state tax\n","(Do NOT assume their entries are correct. You must detect mistakes yourself.)\n","\n","3. Provide Guidance for Correct Form Completion\n","\n","Identify which forms and schedules they actually need (e.g., Schedule C, Schedule SE, Schedule A)\n","- Tell them where each item should be entered\n","- Explain how to correct any issues you spotted\n","- Clarify whether they should itemize or take the standard deduction\n","\n","4. Answer Client Questions and Give Preventative Advice\n","\n","Provide personalized guidance, such as:\n","- whether they can legally claim the dependent\n","- why federal and state figures may differ\n","- how to avoid similar issues next year\n","- recommendations for recordkeeping, estimated tax payments, etc.\n","\"\"\"\n","# ---------------------------------------------------------\n","# 3. Run one model directly on the task\n","# ---------------------------------------------------------\n","def run_model_condition(model_id, model_label, task_prompt):\n","    scenarios = ScenarioList([\n","        Scenario({\n","            \"task_prompt\": task_prompt,\n","            \"condition\": model_label,\n","            \"replicate_id\": i\n","        })\n","        for i in range(N_REPLICATES)\n","    ])\n","\n","    q = QuestionFreeText(\"output\", \"{{ scenario.task_prompt }}\")\n","    survey = Survey([q])\n","\n","    worker = Agent(\n","        instruction=(\n","            \"Complete the task clearly and professionally. Be concise but complete. \"\n","            \"Return only the final deliverable.\"\n","        )\n","    )\n","\n","    print(f\"🚀 Running {model_id} [{model_label}]...\")\n","\n","    results = (\n","        survey.by(scenarios)\n","        .by(worker)\n","        .by(Model(model_id, max_tokens=4096))\n","        .run(\n","            n=1,\n","            progress_bar=False,\n","            verbose=False,\n","            print_exceptions=True,\n","            stop_on_exception=False,\n","            check_api_keys=False,\n","        )\n","    )\n","\n","    df = results.select(\n","        \"scenario.replicate_id\",\n","        \"answer.output\",\n","        \"scenario.condition\"\n","    ).to_pandas()\n","\n","    df.rename(columns={\n","        \"scenario.replicate_id\": \"replicate_id\",\n","        \"answer.output\": \"output\",\n","        \"scenario.condition\": \"condition\",\n","    }, inplace=True)\n","\n","    df[\"model_id\"] = model_id\n","    df[\"model_label\"] = model_label\n","\n","    safe_name = model_label.replace(\" \", \"_\").replace(\":\", \"_\").replace(\"/\", \"_\")\n","    Path(f\"tax-preparer-outputs/automation/{TASK_NAME}/{safe_name}\").mkdir(parents=True, exist_ok=True)\n","    df.to_csv(f\"tax-preparer-outputs/automation/{TASK_NAME}/{safe_name}/outputs.csv\", index=False)\n","\n","    print(f\"💾 Saved {model_label} responses ({len(df)} rows)\")\n","    return df\n","# ---------------------------------------------------------\n","# 4. Main\n","# ---------------------------------------------------------\n","all_results = []\n","\n","for model_id, model_label in TASK_MODELS.items():\n","    model_df = run_model_condition(model_id, model_label, TASK_PROMPT)\n","    all_results.append(model_df)\n","\n","final_df = pd.concat(all_results, ignore_index=True)\n","\n","Path(\"tax-preparer-results\").mkdir(exist_ok=True)\n","output_path = \"tax-preparer-results/tax_preparer_automation_models.csv\"\n","final_df.to_csv(output_path, index=False)\n","\n","print(f\"\\n✅ Exported all results → {output_path} ({len(final_df)} rows)\")\n","print(final_df[[\"replicate_id\", \"condition\", \"model_label\", \"output\"]].head())"],"metadata":{"id":"3Nk1wQ7K6QJW","colab":{"base_uri":"https://localhost:8080/","height":625},"executionInfo":{"status":"ok","timestamp":1773718873316,"user_tz":420,"elapsed":87438,"user":{"displayName":"Kenny Wongchamcharoen","userId":"06797165778644515993"}},"outputId":"d760a849-2149-4b99-c25d-4cbdec04d300"},"execution_count":39,"outputs":[{"output_type":"stream","name":"stdout","text":["🚀 Running gpt-3.5-turbo [GPT-3.5-Turbo]...\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":[]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["💾 Saved GPT-3.5-Turbo responses (1 rows)\n","🚀 Running gpt-4.1 [GPT-4.1]...\n"]},{"output_type":"display_data","data":{"text/plain":["<IPyt