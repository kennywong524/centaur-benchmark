) in zip(ax.patches, summary_df.iterrows()):\n","    x = bar.get_x() + bar.get_width() / 2\n","    y = bar.get_height()\n","    sd = 0.0 if pd.isna(row[\"std\"]) else row[\"std\"]\n","\n","    plt.text(\n","        x,\n","        y + 1.0,\n","        f\"{row['mean']:.1f}%±{sd:.1f}\",\n","        ha=\"center\",\n","        va=\"bottom\",\n","        fontsize=9\n","    )\n","\n","# --- Labels and title ---\n","plt.title(\n","    \"Automation Model Performance on Tax Preparer Task\\n\"\n","    \"(Mean Pairwise Win Rate ± 1 SD Across Runs)\",\n","    fontsize=17,\n","    weight=\"bold\"\n",")\n","plt.ylabel(\"Average Pairwise Win Rate (%)\", fontsize=13)\n","plt.xlabel(\"Automation Model\", fontsize=12)\n","plt.xticks(rotation=30, ha=\"right\", fontsize=11)\n","plt.ylim(0, 100)\n","plt.axhline(50, linestyle=\"--\", color=\"gray\", alpha=0.6)\n","\n","plt.tight_layout()\n","\n","# --- Save & show ---\n","plt.savefig(\"tax_preparer_automation_winrate.png\", dpi=300, bbox_inches=\"tight\")\n","plt.show()"],"metadata":{"id":"tZADB-UpPAf3","colab":{"base_uri":"https://localhost:8080/","height":677},"executionInfo":{"status":"ok","timestamp":1773715364616,"user_tz":420,"elapsed":1096,"user":{"displayName":"Kenny Wongchamcharoen","userId":"06797165778644515993"}},"outputId":"84b25c07-40e3-466c-fdf0-aba0bd2cf7d8"},"execution_count":37,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import shutil\n","from google.colab import files\n","import os\n","\n","output_folder = \"tax-preparer-outputs\"\n","results_folder = \"tax-preparer-results\"\n","zip_name = \"tax-preparer\"\n","\n","# Create the zip archive\n","if os.path.exists(output_folder):\n","    shutil.make_archive(zip_name + \"_outputs\", 'zip', output_folder)\n","    print(f\"Created {zip_name}_outputs.zip\")\n","    files.download(f\"{zip_name}_outputs.zip\")\n","else:\n","    print(f\"Folder '{output_fold